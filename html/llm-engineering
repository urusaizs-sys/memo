<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LLM Engineering Layers</title>
<style>
  :root {
    --bg:        #0D1117;
    --surface:   #161B22;
    --surface2:  #1C2333;
    --border:    #30363D;
    --blue:      #58A6FF;
    --amber:     #F0A500;
    --green:     #3DDC97;
    --red:       #FF6B6B;
    --text:      #E6EDF3;
    --muted:     #8B949E;
    --prompt-c:  #3DDC97;
    --context-c: #58A6FF;
    --harness-c: #F0A500;
    --mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', 'Menlo', monospace;
    --sans: 'Inter', 'Hiragino Sans', 'Noto Sans JP', 'Yu Gothic', system-ui, sans-serif;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–sans);
font-size: 15px;
line-height: 1.7;
min-height: 100vh;
}

header {
border-bottom: 1px solid var(–border);
padding: 20px 40px;
display: flex;
align-items: center;
gap: 16px;
position: sticky;
top: 0;
background: rgba(13,17,23,0.94);
backdrop-filter: blur(8px);
z-index: 100;
}
.logo {
font-family: var(–mono);
font-weight: 700;
font-size: 13px;
color: var(–muted);
letter-spacing: 0.08em;
}
.logo span { color: var(–blue); }
header h1 {
font-family: var(–mono);
font-size: 13px;
font-weight: 600;
color: var(–text);
margin-left: auto;
}

.shell {
display: grid;
grid-template-columns: 220px 1fr;
min-height: calc(100vh - 61px);
}

nav {
border-right: 1px solid var(–border);
padding: 32px 0;
position: sticky;
top: 61px;
height: calc(100vh - 61px);
overflow-y: auto;
}
nav .nav-label {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.12em;
color: var(–muted);
padding: 0 24px 10px;
text-transform: uppercase;
}
nav a {
display: flex;
align-items: center;
gap: 10px;
padding: 9px 24px;
text-decoration: none;
color: var(–muted);
font-size: 13px;
font-weight: 500;
transition: all 0.15s;
border-left: 2px solid transparent;
}
nav a:hover { color: var(–text); background: var(–surface); }
nav a.active { color: var(–text); border-left-color: var(–blue); background: var(–surface); }
nav a .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
nav a.nav-prompt .dot  { background: var(–prompt-c); }
nav a.nav-context .dot { background: var(–context-c); }
nav a.nav-harness .dot { background: var(–harness-c); }

main { padding: 48px 56px; max-width: 860px; }

/* HERO */
.hero { margin-bottom: 56px; }
.hero .eyebrow {
font-family: var(–mono);
font-size: 11px;
letter-spacing: 0.14em;
color: var(–blue);
text-transform: uppercase;
margin-bottom: 14px;
}
.hero h2 {
font-family: var(–mono);
font-size: 30px;
font-weight: 700;
line-height: 1.25;
color: var(–text);
margin-bottom: 16px;
}
.hero p { color: var(–muted); font-size: 15px; max-width: 600px; line-height: 1.8; }

/* LAYER DIAGRAM */
.diagram-wrap { margin-bottom: 56px; }
.diagram-label {
font-family: var(–mono);
font-size: 11px;
letter-spacing: 0.1em;
color: var(–muted);
text-transform: uppercase;
margin-bottom: 16px;
}
.layer {
width: 100%;
border-radius: 10px;
padding: 20px 28px;
cursor: pointer;
transition: all 0.2s;
}
.layer-harness {
background: rgba(240,165,0,0.06);
border: 1.5px solid rgba(240,165,0,0.3);
padding: 24px 28px;
}
.layer-context {
background: rgba(88,166,255,0.06);
border: 1.5px solid rgba(88,166,255,0.3);
margin: 12px 32px 0;
padding: 20px 24px;
}
.layer-prompt {
background: rgba(61,220,151,0.06);
border: 1.5px solid rgba(61,220,151,0.3);
margin: 12px 64px 0;
padding: 16px 20px;
display: flex;
align-items: center;
justify-content: space-between;
}
.layer:hover { transform: scale(1.01); filter: brightness(1.1); }
.layer-tag {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
font-weight: 700;
margin-bottom: 4px;
}
.layer-harness .layer-tag { color: var(–harness-c); }
.layer-context .layer-tag { color: var(–context-c); }
.layer-prompt  .layer-tag { color: var(–prompt-c); }
.layer-title { font-size: 14px; font-weight: 600; color: var(–text); }
.layer-q { font-size: 12px; color: var(–muted); margin-top: 2px; }

/* SECTION */
.section { margin-bottom: 64px; scroll-margin-top: 80px; }
.section-header {
display: flex;
align-items: center;
gap: 14px;
margin-bottom: 24px;
padding-bottom: 16px;
border-bottom: 1px solid var(–border);
}
.section-badge {
font-family: var(–mono);
font-size: 11px;
font-weight: 700;
letter-spacing: 0.08em;
padding: 4px 10px;
border-radius: 4px;
text-transform: uppercase;
}
.badge-prompt  { background: rgba(61,220,151,0.12);  color: var(–prompt-c); }
.badge-context { background: rgba(88,166,255,0.12);  color: var(–context-c); }
.badge-harness { background: rgba(240,165,0,0.12);   color: var(–harness-c); }
.section-title { font-family: var(–mono); font-size: 20px; font-weight: 700; color: var(–text); }

.problem-box {
background: var(–surface);
border: 1px solid var(–border);
border-left: 3px solid var(–red);
border-radius: 8px;
padding: 16px 20px;
margin-bottom: 20px;
font-size: 14px;
}
.problem-box .pb-label {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.1em;
color: var(–red);
text-transform: uppercase;
margin-bottom: 6px;
}
.problem-box p { color: var(–muted); }

.body-text { color: var(–muted); font-size: 14px; line-height: 1.85; margin-bottom: 24px; }
.body-text strong { color: var(–text); font-weight: 600; }

.code-wrap {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
overflow: hidden;
margin-bottom: 20px;
font-family: var(–mono);
font-size: 13px;
}
.code-title {
background: var(–surface2);
border-bottom: 1px solid var(–border);
padding: 8px 16px;
display: flex;
align-items: center;
gap: 8px;
font-size: 11px;
color: var(–muted);
}
.code-title .dot-r { width:10px;height:10px;border-radius:50%;background:#FF5F57; }
.code-title .dot-a { width:10px;height:10px;border-radius:50%;background:#FEBC2E; }
.code-title .dot-g { width:10px;height:10px;border-radius:50%;background:#28C840; }
.code-title .fn { margin-left:6px; }
.code-body { padding: 20px; white-space: pre; overflow-x: auto; line-height: 1.7; }
.c-bad  { color: #FF6B6B; }
.c-good { color: var(–green); }
.c-key  { color: var(–blue); }
.c-str  { color: var(–amber); }
.c-cmt  { color: #555E6B; }
.c-num  { color: #CE91F5; }

.compare { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
.compare-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 16px;
}
.compare-card .cc-label {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
margin-bottom: 10px;
}
.cc-bad  .cc-label { color: var(–red); }
.cc-good .cc-label { color: var(–green); }
.compare-card p { font-family: var(–mono); font-size: 12px; color: var(–muted); line-height: 1.65; }
.compare-card p strong { color: var(–text); }

.flow {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 24px;
margin-bottom: 24px;
}
.flow-label {
font-family: var(–mono);
font-size: 11px;
color: var(–muted);
margin-bottom: 16px;
letter-spacing: 0.08em;
text-transform: uppercase;
}
.flow-row { display: flex; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 4px; }
.flow-row:last-child { margin-bottom: 0; }
.flow-box {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 6px;
padding: 7px 13px;
font-family: var(–mono);
font-size: 12px;
color: var(–text);
white-space: nowrap;
}
.fb-ok   { border-color: var(–green); color: var(–green); }
.fb-warn { border-color: var(–amber); color: var(–amber); }
.fb-crit { border-color: var(–red);   color: var(–red);   }
.fb-log  { border-color: #8957E5;      color: #8957E5; }
.fb-muted{ color: var(–muted); }
.flow-arr { color: var(–muted); font-size: 16px; padding: 0 6px; }
.flow-divider { border-top: 1px solid var(–border); margin: 12px 0; }

.chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
.chip {
font-family: var(–mono);
font-size: 11px;
padding: 4px 12px;
border-radius: 100px;
border: 1px solid;
}
.chip-p { border-color: rgba(61,220,151,0.4); color: var(–prompt-c); background: rgba(61,220,151,0.06); }
.chip-c { border-color: rgba(88,166,255,0.4); color: var(–context-c); background: rgba(88,166,255,0.06); }
.chip-h { border-color: rgba(240,165,0,0.4);  color: var(–harness-c); background: rgba(240,165,0,0.06); }

.summary-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.summary-table th {
font-family: var(–mono);
font-size: 10px;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–muted);
text-align: left;
padding: 10px 14px;
border-bottom: 1px solid var(–border);
font-weight: 600;
}
.summary-table td {
padding: 12px 14px;
border-bottom: 1px solid var(–border);
color: var(–text);
vertical-align: top;
}
.summary-table tr:last-child td { border-bottom: none; }
.summary-table td:first-child { font-family: var(–mono); font-size: 12px; font-weight: 700; }
.summary-table tr:hover td { background: var(–surface2); }

footer {
margin-top: 32px;
padding: 24px 56px;
border-top: 1px solid var(–border);
font-family: var(–mono);
font-size: 11px;
color: var(–muted);
letter-spacing: 0.06em;
}
</style>

</head>

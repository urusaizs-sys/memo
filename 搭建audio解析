## 第七步：完整流程脚本

将以下内容保存为 `transcribe_meeting.py`，放在你的工作目录中：

```python
import os
import sys
import whisper
import json
from anthropic import Anthropic
from pyannote.audio import Pipeline
from dotenv import load_dotenv

load_dotenv()

def transcribe_with_diarization(audio_path: str) -> str:
    """说话人分离 + 语音转文字"""
    
    print("🔍 步骤 1/3：说话人分离中...")
    hf_token = os.getenv("HF_TOKEN")
    pipeline = Pipeline.from_pretrained(
        "pyannote/speaker-diarization-3.1",
        use_auth_token=hf_token
    )
    diarization = pipeline(audio_path)
    
    print("📝 步骤 2/3：语音转文字中（large-v3 模型）...")
    model = whisper.load_model("large-v3")
    result = model.transcribe(audio_path, language=None)  # 自动检测中/日文
    
    # 将说话人信息与转录文本合并
    print("🔗 步骤 3/3：合并说话人与文字...")
    segments = result["segments"]
    transcript_lines = []
    
    for segment in segments:
        start = segment["start"]
        end = segment["end"]
        text = segment["text"].strip()
        
        # 找到这个时间段的说话人
        speaker = "未知"
        for turn, _, spk in diarization.itertracks(yield_label=True):
            if turn.start <= start and turn.end >= end:
                speaker = spk
                break
        
        timestamp = f"[{int(start//60):02d}:{int(start%60):02d}]"
        transcript_lines.append(f"{timestamp} {speaker}: {text}")
    
    return "\n".join(transcript_lines)


def generate_minutes(transcript: str) -> str:
    """用 Claude 整理会议纪要"""
    
    print("🤖 正在用 Claude 整理会议纪要...")
    client = Anthropic()
    
    prompt = f"""以下是一段中日双语会议的转录文字（含说话人标注）。

请整理成结构化的会议纪要，要求：
1. 输出语言：中文
2. 保留专业术语原文（中文和日文术语均保留）
3. 结构包含：会议概要、主要议题、关键讨论点、决策事项、待办行动项（含负责人）
4. 如有日文内容，翻译成中文后摘要

转录内容：
---
{transcript}
---

请输出 Markdown 格式的会议纪要。"""

    message = client.messages.create(
        model="claude-opus-4-6",
        max_tokens=4096,
        messages=[{"role": "user", "content": prompt}]
    )
    
    return message.content[0].text


def main():
    if len(sys.argv) < 2:
        print("用法：python transcribe_meeting.py meeting.mp3")
        sys.exit(1)
    
    audio_path = sys.argv[1]
    output_path = audio_path.replace(".mp3", "_会议纪要.md")
    
    # 转录
    transcript = transcribe_with_diarization(audio_path)
    
    # 保存原始转录
    transcript_path = audio_path.replace(".mp3", "_转录原文.txt")
    with open(transcript_path, "w", encoding="utf-8") as f:
        f.write(transcript)
    print(f"✅ 转录原文已保存：{transcript_path}")
    
    # 生成会议纪要
    minutes = generate_minutes(transcript)
    
    with open(output_path, "w", encoding="utf-8") as f:
        f.write(minutes)
    print(f"✅ 会议纪要已保存：{output_path}")


if __name__ == "__main__":
    main()
```

### 使用方式

```powershell
